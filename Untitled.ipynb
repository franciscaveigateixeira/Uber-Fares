    "from sklearn.manifold import TSNE\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"T-SNE DIMENSIONALITY REDUCTION\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Use a sample for t-SNE (computationally intensive)\n",
    "tsne_sample_size = 15000\n",
    "np.random.seed(42)\n",
    "tsne_indices = np.random.choice(len(X_scaled), tsne_sample_size, replace=False)\n",
    "X_tsne_sample = X_scaled[tsne_indices]\n",
    "cluster_tsne_sample = df['cluster'].iloc[tsne_indices].values\n",
    "\n",
    "print(f\"Running t-SNE on {tsne_sample_size:,} samples... (this may take 1-2 minutes)\")\n",
    "\n",
    "# Apply t-SNE\n",
    "tsne = TSNE(n_components=2, random_state=42, perplexity=30, max_iter=1000)\n",
    "tsne_result = tsne.fit_transform(X_tsne_sample)\n",
    "\n",
    "# Create dataframe for plotting\n",
    "tsne_df = pd.DataFrame({\n",
    "    'tsne_x': tsne_result[:, 0],\n",
    "    'tsne_y': tsne_result[:, 1],\n",
    "    'cluster': cluster_tsne_sample\n",
    "})\n",
    "\n",
    "# Plot t-SNE results\n",
    "fig, ax = plt.subplots(figsize=(12, 8))\n",
    "\n",
    "scatter = ax.scatter(tsne_df['tsne_x'], tsne_df['tsne_y'], \n",
    "                     c=tsne_df['cluster'], cmap='tab10', \n",
    "                     alpha=0.5, s=8)\n",
    "ax.set_xlabel('t-SNE Component 1')\n",
    "ax.set_ylabel('t-SNE Component 2')\n",
    "ax.set_title('t-SNE Visualization of Trip Clusters', fontweight='bold')\n",
    "plt.colorbar(scatter, ax=ax, label='Cluster')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
